<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pilates 30-Day Program</title>
    <link rel="stylesheet" href="style.css">
</head>

<body>
    <header>
        <h1>Pilates</h1>
        <p>Move with Intention</p>
    </header>

    <div class="container">
        <aside class="sidebar">
            <h2>Days</h2>
            <ul id="day-list">
                <!-- Sidebar days will be injected by JS -->
            </ul>
        </aside>

        <main class="content">
            <div id="day-content">
                <!-- Day content injected by JS -->
            </div>
            <button id="joinBtn">Join Program</button>
        </main>
    </div>

    <script src="script.js"></script>
</body>

</html>